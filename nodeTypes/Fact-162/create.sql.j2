{# == Node Type Name           : Fact  == #}
{# == Node Type Description    : This node creates fact table, view and also override create sql for view  == #}

{# Override CreateSQL for view #}
{%- if node.override.create.enabled and node.materializationType == 'view' %}
	
    {{ node.override.create.script }}

{%- elif node.materializationType == 'table' %}

    {# CreateSQL for Table #}  
    {{ stage('Create Fact Table') }}
    CREATE OR REPLACE TABLE {{ ref_no_link(node.location.name, node.name) }}
    (
        {%- for col in columns %}
            `{{ col.name }}` {{ col.dataType }}
            {%- if col.defaultValue | length > 0 %}DEFAULT {{ col.defaultValue }}{%- endif %}
            {%- if  not col.nullable %} NOT NULL {%- endif %}
            {%- if col.description | length > 0 %} OPTIONS(description="{{ col.description | escape }}"){%- endif %}
            {%- if not loop.last -%}, {%- endif %}
        {%- endfor %}
    )
    {%- if node.description | length > 0 %} OPTIONS(description="{{ node.description | escape }}"){%- endif %}
       
{%- elif node.materializationType == 'view' and node.override.create.enabled == false %}
        
    {# CreateSQL for View #}
    {{ stage('Create Fact View') }}
    CREATE OR REPLACE VIEW {{ ref_no_link(node.location.name, node.name) }}
    (
        {%- for col in columns %}
            `{{ col.name }}`
            {%- if col.description | length > 0 %}OPTIONS(description="{{ col.description | escape }}"){%- endif %}
            {%- if not loop.last -%},{%- endif %}
        {%- endfor %}
    )
    {%- if node.description | length > 0 %} OPTIONS(description="{{ node.description | escape }}"){%- endif %}
    AS
    {%- for source in sources %}
    (
        SELECT
        {%- if config.selectDistinct %} DISTINCT {%- endif %}
        {%- for col in source.columns %}
            {{ get_source_transform(col) }} AS `{{ col.name }}`
            {%- if not loop.last -%}, {%- endif %}
        {%- endfor %}
        {{ source.join }}
        {%- if config.groupByAll %} GROUP BY ALL {%- endif %}
    )
        {%- if config.insertStrategy in ['UNION DISTINCT', 'UNION ALL'] and not loop.last %}
            {{config.insertStrategy}}
        {%- endif %}
    {%- endfor %}
    
{%- endif %}